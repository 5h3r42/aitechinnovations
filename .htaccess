RewriteEngine On
Options -MultiViews

RewriteCond %{HTTP_HOST} ^aitechinnovations\.com$ [NC]
RewriteRule ^ https://www.aitechinnovations.com%{REQUEST_URI} [R=301,L,NE]

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+ai-automation-services\.html[\s?] [NC]
RewriteRule ^ai-automation-services\.html$ /ai-automation-services [R=301,L]
RewriteCond %{THE_REQUEST} \s/+ai-chatbot-development\.html[\s?] [NC]
RewriteRule ^ai-chatbot-development\.html$ /ai-chatbot-development [R=301,L]
RewriteCond %{THE_REQUEST} \s/+ai-lead-generation-automation\.html[\s?] [NC]
RewriteRule ^ai-lead-generation-automation\.html$ /ai-lead-generation-automation [R=301,L]
RewriteCond %{THE_REQUEST} \s/+crm-automation-services\.html[\s?] [NC]
RewriteRule ^crm-automation-services\.html$ /crm-automation-services [R=301,L]
RewriteCond %{THE_REQUEST} \s/+appointment-booking-automation\.html[\s?] [NC]
RewriteRule ^appointment-booking-automation\.html$ /appointment-booking-automation [R=301,L]
RewriteCond %{THE_REQUEST} \s/+free-ai-audit\.html[\s?] [NC]
RewriteRule ^free-ai-audit\.html$ /free-ai-audit [R=301,L]
RewriteCond %{THE_REQUEST} \s/+free-strategy-call\.html[\s?] [NC]
RewriteRule ^free-strategy-call\.html$ /free-strategy-call [R=301,L]
RewriteCond %{THE_REQUEST} \s/+website-content-services\.html[\s?] [NC]
RewriteRule ^website-content-services\.html$ /website-content-services [R=301,L]
RewriteCond %{THE_REQUEST} \s/+ads-setup-services\.html[\s?] [NC]
RewriteRule ^ads-setup-services\.html$ /ads-setup-services [R=301,L]
RewriteCond %{THE_REQUEST} \s/+blog\.html[\s?] [NC]
RewriteRule ^blog\.html$ /blog [R=301,L]
RewriteCond %{THE_REQUEST} \s/+blog-how-small-businesses-use-ai\.html[\s?] [NC]
RewriteRule ^blog-how-small-businesses-use-ai\.html$ /blog/how-small-businesses-use-ai [R=301,L]
RewriteCond %{THE_REQUEST} \s/+blog-what-is-ai-workflow-automation\.html[\s?] [NC]
RewriteRule ^blog-what-is-ai-workflow-automation\.html$ /blog/what-is-ai-workflow-automation [R=301,L]
RewriteCond %{THE_REQUEST} \s/+blog-ai-chatbots-for-customer-service\.html[\s?] [NC]
RewriteRule ^blog-ai-chatbots-for-customer-service\.html$ /blog/ai-chatbots-for-customer-service [R=301,L]
RewriteCond %{THE_REQUEST} \s/+privacy\.html[\s?] [NC]
RewriteRule ^privacy\.html$ /privacy [R=301,L]
RewriteCond %{THE_REQUEST} \s/+terms\.html[\s?] [NC]
RewriteRule ^terms\.html$ /terms [R=301,L]

RewriteRule ^ai-automation-services/?$ ai-automation-services.html [L]
RewriteRule ^ai-chatbot-development/?$ ai-chatbot-development.html [L]
RewriteRule ^ai-lead-generation-automation/?$ ai-lead-generation-automation.html [L]
RewriteRule ^crm-automation-services/?$ crm-automation-services.html [L]
RewriteRule ^appointment-booking-automation/?$ appointment-booking-automation.html [L]
RewriteRule ^free-ai-audit/?$ free-ai-audit.html [L]
RewriteRule ^free-strategy-call/?$ free-strategy-call.html [L]
RewriteRule ^website-content-services/?$ website-content-services.html [L]
RewriteRule ^ads-setup-services/?$ ads-setup-services.html [L]
RewriteRule ^blog/?$ blog.html [L]
RewriteRule ^blog/how-small-businesses-use-ai/?$ blog-how-small-businesses-use-ai.html [L]
RewriteRule ^blog/what-is-ai-workflow-automation/?$ blog-what-is-ai-workflow-automation.html [L]
RewriteRule ^blog/ai-chatbots-for-customer-service/?$ blog-ai-chatbots-for-customer-service.html [L]
RewriteRule ^privacy/?$ privacy.html [L]
RewriteRule ^terms/?$ terms.html [L]

<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js|webp|png|jpg|jpeg|svg)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
</IfModule>
