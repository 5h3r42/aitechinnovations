RewriteEngine On
Options -MultiViews

RewriteCond %{HTTP_HOST} ^aitechinnovations\.com$ [NC]
RewriteRule ^ https://www.aitechinnovations.com%{REQUEST_URI} [R=301,L,NE]

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Preserve authority from the four former .html canonical URLs.
RewriteCond %{THE_REQUEST} \s/+about\.html[\s?] [NC]
RewriteRule ^about\.html$ /about/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+website-design-maidstone\.html[\s?] [NC]
RewriteRule ^website-design-maidstone\.html$ /website-design-maidstone/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+website-design-kent\.html[\s?] [NC]
RewriteRule ^website-design-kent\.html$ /website-design-kent/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+website-design-london\.html[\s?] [NC]
RewriteRule ^website-design-london\.html$ /website-design-london/ [R=301,L]

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://*.clarity.ms; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://analytics.google.com https://*.analytics.google.com https://*.clarity.ms https://www.googleadservices.com https://*.doubleclick.net https://scripts.google.com https://script.google.com https://script.googleusercontent.com https://*.googleusercontent.com https://formsubmit.co https://*.supabase.co https://app.aitechinnovations.com; img-src 'self' data: https://www.google-analytics.com https://*.google-analytics.com https://*.clarity.ms https://www.googleadservices.com https://*.doubleclick.net; style-src 'self' 'unsafe-inline'; font-src 'self'; frame-src https://calendar.google.com; base-uri 'self'; form-action 'self' https://formsubmit.co; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests"
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js|webp|png|jpg|jpeg|svg)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
</IfModule>

RewriteRule ^api/knowledge/ - [F,L,NC]
